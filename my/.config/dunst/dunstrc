[global]
alignment = left
always_run_script = true
background = "#355e3b"
ellipsize = end
follow = mouse
font = JetBrains Mono Regular 12
force_xinerama = false
foreground = "#faf9f6"
format = "<b>%s</b>\n%b"
frame_color = "#000000"
frame_width = 5
height = 500
hide_duplicate_count = false
history_length = 20
horizontal_padding = 20
icon_position = off
idle_threshold = 120
ignore_newline = false
indicate_hidden = true
line_height = 2
markup = full
origin = top-right
padding = 50
separator_color = "#000000"
separator_height = 5
show_age_threshold = -1
show_indicators = false
shrink = true
sort = true
stack_duplicates = true
sticky_history = true
timeout = 3
transparency = 0
width = 400
word_wrap = true

[stuck]
stack_tag = "my"
