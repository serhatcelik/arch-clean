[global]
alignment = left
always_run_script = true
background = "#355e3b"
class = Dunst
ellipsize = end
follow = mouse
font = JetBrains Mono Regular 14
force_xinerama = false
foreground = "#faf9f6"
format = "<b>%s</b>\n%b"
frame_color = "#000000"
frame_width = 10
height = 500
hide_duplicate_count = false
history_length = 20
horizontal_padding = 50
idle_threshold = 120
ignore_newline = no
indicate_hidden = yes
line_height = 2
markup = full
origin = top-right
padding = 50
separator_height = 0
show_age_threshold = -1
show_indicators = false
shrink = yes
sort = yes
stack_duplicates = true
sticky_history = yes
timeout = 2
title = Dunst
transparency = 0
width = 400
word_wrap = yes

[stack-my]
set_stack_tag = "my"
