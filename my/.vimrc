highlight Trail ctermbg=red
autocmd ColorScheme * highlight Trail ctermbg=red
match Trail /\s\+$/
filetype indent on
filetype on
filetype plugin on
inoremap <S-Tab> <C-d>
set expandtab
set expandtab
set history=10000
set incsearch
set laststatus=2
set nobackup
set noshowmatch
set scrolloff=8
set shiftwidth=4
set showmode
set smartindent
set softtabstop=4
set tabstop=4
set whichwrap+=<,>,[,]
syntax on
